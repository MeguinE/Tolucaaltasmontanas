---
import Logo from "./Logo.astro";
---

<header
  class="fixed top-0 left-0 w-full flex items-center justify-between py-4 px-8 border-b border-red-700 bg-white/90 backdrop-blur-md text-black z-50 shadow-sm"
>
  <a
    href="#hero"
    class="flex items-center hover:opacity-90 transition-opacity duration-300"
  >
    <Logo />
  </a>

  <!-- Navegación desktop -->
  <nav class="hidden md:flex gap-6 text-sm font-semibold tracking-wide uppercase">
    <a href="/" class="text-black hover:text-red-600 transition-colors duration-300">Inicio</a>
    <a href="#training" class="text-black hover:text-red-600 transition-colors duration-300">Categorías</a>
    <a href="#about" class="text-black hover:text-red-600 transition-colors duration-300">Nosotros</a>
    <a href="#registro" class="text-black hover:text-red-600 transition-colors duration-300">Registro</a>
    <a href="#gallery" class="text-black hover:text-red-600 transition-colors duration-300">Galería</a>
    <a
      href="/admin/"
      class="px-4 py-1.5 rounded-lg bg-red-700 text-white hover:bg-red-800 transition-colors duration-300"
    >Admin</a>
  </nav>

  <!-- Botón hamburguesa mobile -->
  <button
    id="menu-toggle"
    class="md:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-red-50 transition"
    aria-label="Menú"
  >
    <span class="block w-6 h-0.5 bg-black transition-all duration-300" id="bar1"></span>
    <span class="block w-6 h-0.5 bg-black transition-all duration-300" id="bar2"></span>
    <span class="block w-6 h-0.5 bg-black transition-all duration-300" id="bar3"></span>
  </button>
</header>

<!-- Menú móvil drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden"
>
  <!-- Overlay -->
  <div id="menu-overlay" class="absolute inset-0 bg-black/40"></div>

  <!-- Panel -->
  <nav
    class="absolute right-0 top-0 h-full w-72 bg-white shadow-2xl flex flex-col pt-6 pb-8"
  >
    <div class="flex items-center justify-between px-6 mb-8">
      <span class="text-red-700 font-extrabold text-lg uppercase tracking-wider">Menú</span>
      <button id="menu-close" class="p-2 rounded-lg hover:bg-red-50 transition" aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="flex flex-col gap-1 px-4">
      <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-black hover:bg-red-50 hover:text-red-700 transition">🏠 Inicio</a>
      <a href="#training" class="flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-black hover:bg-red-50 hover:text-red-700 transition">⚽ Categorías</a>
      <a href="#about" class="flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-black hover:bg-red-50 hover:text-red-700 transition">🏆 Nosotros</a>
      <a href="#registro" class="flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-black hover:bg-red-50 hover:text-red-700 transition">📝 Registro</a>
      <a href="#gallery" class="flex items-center gap-3 px-4 py-3 rounded-xl font-semibold text-black hover:bg-red-50 hover:text-red-700 transition">📸 Galería</a>
    </div>

    <div class="mt-auto px-4">
      <a
        href="/admin/"
        class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-red-700 text-white font-bold hover:bg-red-800 transition"
      >
        🔐 Panel Admin
      </a>
    </div>
  </nav>
</div>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const overlay = document.getElementById("menu-overlay");
  const close = document.getElementById("menu-close");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  const bar3 = document.getElementById("bar3");

  function openMenu() {
    menu?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    menu?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", openMenu);
  close?.addEventListener("click", closeMenu);
  overlay?.addEventListener("click", closeMenu);

  // Cerrar al hacer clic en un enlace del menú móvil
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>
